  <data name="colExactMatch.ToolTip" xml:space="preserve">
    <value>Use this option if you do not require to search for similar records.  Most common uses for exact matching are email addresses, telephone numbers, ZIP codes etc, and also the processing is much quicker than using fuzzy match</value>
  </data>
